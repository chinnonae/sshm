{
  "name": "sshm",
  "version": "0.1.0",
  "description": "CLI SSH config manager with groups and interactive mode",
  "module": "src/index.ts",
  "bin": {
    "sshm": "./src/index.ts"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile src/index.ts --outfile dist/sshm",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0"
  }
}
